# Development Tools Aliases
# ----------------------------

# Git Shortcuts
alias gc='git commit -a -m'                  # Commit all changes
alias ga='git add'                           # Stage files
alias gp='git push'                          # Push changes
alias gu='git pull'                          # Pull changes
alias gcl='git clone'                        # Clone repository
alias gs='git status'                        # Check status
alias gl='git log --oneline'                 # Compact git log
alias gd='git diff'                          # Show changes
alias gb='git branch'                        # List branches
alias gco='git checkout'                     # Switch branches
alias greset='git reset --hard'              # Hard reset changes
alias gclean='git clean -fd'                 # Remove untracked files

# Advanced Git
alias gstash='git stash'                     # Stash changes
alias gstash-pop='git stash pop'             # Pop the last stash
alias gmerge='git merge'                     # Merge branches
alias grebase='git rebase'                   # Rebase changes
alias gamend='git commit --amend --no-edit'  # Amend last commit
alias gundo='git reset HEAD~1'               # Undo last commit (keep changes)

# Docker Shortcuts
alias dps='docker ps'                        # List containers
alias dimg='docker images'                   # List images
alias dstop='docker stop $(docker ps -q)'    # Stop all containers
alias drm='docker rm $(docker ps -a -q)'     # Remove all containers
alias dprune='docker system prune -a'        # Remove unused data
alias dbuild='docker build -t'               # Build Docker image
alias drun='docker run -it'                  # Run container interactively
alias dlogs='docker logs'                    # View container logs
alias dexec='docker exec -it'                # Exec into running container

# Kubernetes Shortcuts
alias k='kubectl'                            # Shorten kubectl command
alias kctx='kubectl config use-context'      # Switch contexts
alias kns='kubectl config set-context --current --namespace' # Set namespace
alias kget='kubectl get'                     # Get Kubernetes resources
alias kdesc='kubectl describe'               # Describe resources
alias kdel='kubectl delete'                  # Delete resources
alias klogs='kubectl logs'                   # View pod logs
alias kexec='kubectl exec -it'               # Exec into a pod

# AI Development
alias aiderg='aider --model gemini/gemini-1.5-pro-latest'  # Use Aider AI
alias ollama-run='ollama run'                # Quick Ollama model run
alias whisper='whisper-ctranslate2'          # Speech-to-text shortcut
alias train='python train.py'                # Start training
alias eval='python evaluate.py'              # Evaluate model

# Android Development
alias scrcpy="scrcpy -b 8M --window-title='Pixel' --max-fps=55 --no-audio"
alias ex-scrcpy='/home/azzar/Documents/script/scrcpy-scripts/virtual_display.sh'
alias adb-restart='adb kill-server && adb start-server'  # Restart ADB
alias adb-screenshot='adb exec-out screencap -p > screen-$(date +%s).png'  # Take screenshot
alias adb-record='adb shell screenrecord /sdcard/recording.mp4'  # Record screen

# Node.js/NPM Shortcuts
alias ni='npm install'                       # Install dependencies
alias nr='npm run'                           # Run scripts
alias ns='npm start'                         # Start the app
alias nt='npm test'                          # Run tests
alias nl='npm list --depth=0'                # List installed packages

# Python Shortcuts
alias py='python3'                           # Shortcut for Python 3
alias pipu='pip install --upgrade'           # Upgrade packages
alias pipr='pip install -r requirements.txt' # Install from requirements file

# Virtual Environment Management
alias venv-create='python3 -m venv .venv'    # Create virtual environment
alias venv-activate='source .venv/bin/activate' # Activate virtual environment
alias venv-deactivate='deactivate'           # Deactivate virtual environment
alias venv-remove='rm -rf .venv'             # Remove virtual environment

# Local Development Server
alias pyserve='python3 -m http.server 8000'  # Start simple HTTP server (default port: 8000)
alias pyserve-https='python3 -m http.server 443 --bind 127.0.0.1'  # Serve HTTPS (custom setup)

# Testing & Linting
alias pytest='python3 -m pytest'             # Run tests with Pytest
alias pytest-verbose='pytest -v'             # Run tests with verbose output
alias pylint='python3 -m pylint'             # Run Pylint on code
alias black='python3 -m black'               # Format code with Black
alias isort='python3 -m isort .'             # Sort imports with isort
alias mypy='python3 -m mypy'                 # Run MyPy type checker

# Dependency Management
alias pip-freeze='pip freeze > requirements.txt' # Freeze dependencies
alias pip-check='pip check'                   # Check for dependency conflicts
alias pip-outdated='pip list --outdated'      # List outdated packages

# Common Development Commands
alias pydebug='python3 -m pdb'                # Debug Python script
alias pyprofile='python3 -m cProfile -s time' # Profile Python code
alias pycompile='python3 -m compileall .'     # Compile all Python files
alias pyshell='python3 -i'                    # Start interactive Python shell
alias pyspeed='python3 -m timeit'             # Measure execution time of code snippets

# Notebook Shortcuts
alias jn='jupyter notebook'                   # Start Jupyter Notebook
alias jl='jupyter lab'                        # Start Jupyter Lab
alias nbconvert='jupyter nbconvert --to html' # Convert notebooks to HTML

# Package Management
alias pip-uninstall-all='pip freeze | xargs pip uninstall -y' # Uninstall all packages
alias pyenv-list='pyenv versions'             # List Python versions (if pyenv is used)
alias pyenv-global='pyenv global'             # Set global Python version

# Additional Tools
alias poetry='poetry'                         # Shortcut for Poetry
alias tox='tox'                               # Run tests in isolated environments
alias pyinstaller='pyinstaller --onefile'     # Create standalone executables
